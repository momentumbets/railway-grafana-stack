ARG VERSION=12.3.3

FROM grafana/grafana-oss:${VERSION}

USER root

# Fetch and validate the Git-backed Momentum Bets dashboard/alert seed before Grafana starts.
# The base image is currently Alpine-based, but keep an apt fallback for future tags.
RUN if command -v apk >/dev/null 2>&1; then \
      apk add --no-cache curl unzip ca-certificates python3; \
    elif command -v apt-get >/dev/null 2>&1; then \
      apt-get update \
      && apt-get install -y --no-install-recommends curl unzip ca-certificates python3 \
      && rm -rf /var/lib/apt/lists/*; \
    else \
      echo "No supported package manager found for installing curl/unzip" >&2; \
      exit 1; \
    fi

# Copy custom config for JSON logging
COPY grafana.ini /etc/grafana/grafana.ini

# Copy the datasources and static provisioning config in this repository.
COPY datasources /etc/grafana/provisioning/datasources
COPY load-mb-stack-grafana-gitops.sh /usr/local/bin/load-mb-stack-grafana-gitops.sh
COPY validate-mb-stack-grafana-alerting.py /usr/local/bin/validate-mb-stack-grafana-alerting.py

RUN chmod +x /usr/local/bin/load-mb-stack-grafana-gitops.sh \
    /usr/local/bin/validate-mb-stack-grafana-alerting.py \
    && mkdir -p /etc/grafana/provisioning/dashboards \
      /etc/grafana/provisioning/alerting \
      /var/lib/grafana/dashboards/mb-stack \
    && chown -R 472:0 /etc/grafana/provisioning/dashboards \
      /etc/grafana/provisioning/alerting \
      /var/lib/grafana/dashboards

USER 472

ENTRYPOINT ["/usr/local/bin/load-mb-stack-grafana-gitops.sh"]
CMD ["/run.sh"]
